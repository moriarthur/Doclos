# ============================================================================
# Doclos Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://doclos:doclos_dev_password@localhost:5432/doclos?schema=public"
DB_HOST="localhost"
DB_PORT="5432"
DB_USERNAME="doclos"
DB_PASSWORD="doclos_dev_password"
DB_NAME="doclos"

# ----------------------------------------------------------------------------
# Redis Configuration (BullMQ Queue)
# ----------------------------------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="30d"

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_NAME="Doclos"
APP_ENV="development"
APP_PORT=3001
APP_URL="http://localhost:3001"
NODE_ENV="development"

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# S3 / R2 Storage Configuration
# ----------------------------------------------------------------------------
# For AWS S3: Use "us-east-1" or your region
# For Cloudflare R2: Use "auto"
S3_REGION="auto"

# For Cloudflare R2: Set your R2 endpoint
# For AWS S3: Leave empty
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# Bucket name
S3_BUCKET="doclos-documents"

# Access credentials
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Signed URL expiration (in seconds, default 24 hours)
S3_SIGNED_URL_EXPIRATION="86400"

# ----------------------------------------------------------------------------
# AI Services
# ----------------------------------------------------------------------------
# Anthropic Claude API (primary LLM)
ANTHROPIC_API_KEY=""

# OpenAI API (fallback LLM)
OPENAI_API_KEY=""

# ----------------------------------------------------------------------------
# OCR Configuration
# ----------------------------------------------------------------------------
# Google Cloud Vision API (fallback for low-confidence OCR)
GOOGLE_CREDENTIALS_JSON=""

# Tesseract language data (default: German + English)
TESSERACT_LANGUAGES="deu+eng"

# ----------------------------------------------------------------------------
# File Upload Settings
# ----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES="application/pdf,image/png,image/jpeg,image/tiff"

# ----------------------------------------------------------------------------
# Processing Configuration
# ----------------------------------------------------------------------------
# Confidence thresholds (Part 3: AI Pipeline)
CONFIDENCE_AUTO_ACCEPT="0.85"
CONFIDENCE_NEEDS_VALIDATION="0.60"

# OCR fallback threshold
OCR_FALLBACK_THRESHOLD="0.70"

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
UPLOAD_RATE_LIMIT="20"  # requests per minute
SEARCH_RATE_LIMIT="60"  # requests per minute
