# ============================================================================
# Doclos Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# Primary connection string — the only DB var the app reads (TypeORM).
# Production uses the Supabase IPv4 pooler (transaction mode, port 6543):
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Local Docker (see docker/docker-compose.yml):
# DATABASE_URL="postgresql://doclos:doclos_dev_password@localhost:5432/doclos"

# ----------------------------------------------------------------------------
# Redis Configuration (BullMQ Queue)
# ----------------------------------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="30d"

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_NAME="Doclos"
APP_ENV="development"
APP_PORT=3001
APP_URL="http://localhost:3001"
NODE_ENV="development"

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# S3 / R2 Storage Configuration
# ----------------------------------------------------------------------------
# For AWS S3: Use "us-east-1" or your region
# For Cloudflare R2: Use "auto"
S3_REGION="auto"

# For Cloudflare R2: Set your R2 endpoint
# For AWS S3: Leave empty
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# Bucket name
S3_BUCKET="doclos-documents"

# Access credentials
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Signed URL expiration (in seconds, default 24 hours)
S3_SIGNED_URL_EXPIRATION="86400"

# ----------------------------------------------------------------------------
# AI Services — GLM (Zhipu AI / Z.ai)
# ----------------------------------------------------------------------------
# The only LLM provider wired up is GLM (open.bigmodel.cn). Get a key at
# https://open.bigmodel.cn — there is no Claude/OpenAI fallback in the app.
GLM_API_KEY=""
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
# glm-4-flash = fast/cheap (code default); glm-4.7-flash = reasoning model (currently in use)
GLM_MODEL="glm-4-flash"
# Comma-separated fallback models tried when GLM_MODEL is overloaded (429 / 5xx /
# timeout) on Z.ai. glm-4.7-flash rate-limits in peak hours; glm-4.5-flash is a
# free flash-family alternative. Leave unset to use the built-in default.
GLM_FALLBACK_MODELS="glm-4.5-flash"

# ----------------------------------------------------------------------------
# OCR Configuration
# ----------------------------------------------------------------------------
# OCR is Tesseract.js only (deu+eng). No cloud-OCR fallback is implemented.
TESSERACT_LANGUAGES="deu+eng"

# ----------------------------------------------------------------------------
# File Upload Settings
# ----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES="application/pdf,image/png,image/jpeg,image/tiff"

# ----------------------------------------------------------------------------
# Processing Configuration
# ----------------------------------------------------------------------------
# Confidence thresholds (Part 3: AI Pipeline)
CONFIDENCE_AUTO_ACCEPT="0.85"
CONFIDENCE_NEEDS_VALIDATION="0.60"

# OCR fallback threshold
OCR_FALLBACK_THRESHOLD="0.70"

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
UPLOAD_RATE_LIMIT="20"  # requests per minute
SEARCH_RATE_LIMIT="60"  # requests per minute
